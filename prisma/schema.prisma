// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  lastName String
  email    String @unique
  phone    String? @unique
  password String

  profileImg String?
  bannerImg  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  addresses Address[]
  pets      Pet[]

  preferences UserPreference[]

  views  validateView[]
  hearts validadeHeart[]
}

model Address {
  id           Int    @id @default(autoincrement())
  userId       Int
  cep          String
  street       String
  neighborhood String
  city         String
  state        String

  User User @relation(fields: [userId], references: [id])
}

model petAddress {
  id           Int    @id @default(autoincrement())
  petId        Int    @unique
  cep          String
  street       String
  neighborhood String
  city         String
  state        String

  Pet Pet @relation(fields: [petId], references: [id])
}

model validateView {
  id       Int      @id @default(autoincrement())
  petId    Int
  userId   Int
  viewDate DateTime @db.Date

  Pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([petId, userId, viewDate])
  @@index([petId, userId])
}

model validadeHeart {
  id     Int @id @default(autoincrement())
  petId  Int
  userId Int

  Pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([petId, userId])
  @@index([petId, userId])
}

model Pet {
  id        Int    @id @default(autoincrement())
  userId    Int
  name      String
  type      String
  breed     String
  gender    String
  wayOfLyfe String
  age       String
  details   String

  publishedAt DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  viewsCount  Int      @default(0)
  heartsCount Int      @default(0)

  toy        String
  food       String
  playPlace  String
  sleepPlace String

  imgs    petImg[]
  address petAddress?

  traits PetTrait[]

  views  validateView[]
  hearts validadeHeart[]

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model petImg {
  id    Int    @id @default(autoincrement())
  petId Int
  url   String

  Pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Trait {
  id        Int    @id @default(autoincrement())
  key       String @unique
  sortOrder Int    @default(0)

  petTraits       PetTrait[]
  userPreferences UserPreference[]
}

model PetTrait {
  id      Int @id @default(autoincrement())
  petId   Int
  traitId Int
  value   Int

  Pet   Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  Trait Trait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([petId, traitId])
}

model UserPreference {
  id      Int @id @default(autoincrement())
  userId  Int
  traitId Int
  weight  Int @default(0)

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Trait Trait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([userId, traitId])
}
