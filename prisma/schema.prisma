// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  lastName String
  email    String @unique
  phone    String @unique
  password String

  addresses Address[]
  // pets Pet[]
  pets      Pet[]
}

model Address {
  id           Int    @id @default(autoincrement())
  User         User   @relation(fields: [userId], references: [id])
  userId       Int
  cep          String
  street       String
  neighborhood String
  city         String
  state        String
}

model petAddress {
  id           Int    @id @default(autoincrement())
  Pet   Pet    @relation(fields: [petId], references: [id])
  petId        Int @unique
  cep          String
  street       String
  neighborhood String
  city         String
  state        String
}

model Pet {
  id      Int      @id @default(autoincrement())
  User    User     @relation(fields: [userId], references: [id])
  userId  Int
  name    String
  type    String
  breed   String
  age     String
  details String

  imgs    petImg[]
  address petAddress?
}

model petImg {
  id    Int    @id @default(autoincrement())
  Pet   Pet    @relation(fields: [petId], references: [id])
  petId Int
  url   String
}
