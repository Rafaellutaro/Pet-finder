// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  lastName String
  email    String  @unique
  phone    String? @unique
  password String

  profileImg String?
  bannerImg  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  pets      Pet[]

  preferences UserPreference[]

  views  validateView[]
  hearts validadeHeart[]

  notification Notification[]

  adoptedConversations Conversation[] @relation("ConversationAdopter")
  ownedConversations   Conversation[] @relation("ConversationOwner")
  sendedMessages       Message[]      @relation("userSentMessages")

  createdMeetingProposals   MeetingProposal[] @relation("MeetingProposalCreatedBy")
  respondedMeetingProposals MeetingProposal[] @relation("MeetingProposalRespondedBy")

  adoptedRecord PetsAdopted[]
}

enum AddressType {
  MAIN
  SECONDARY
  MEETINGPROPOSE
  OTHER
}

model Address {
  id           Int         @id @default(autoincrement())
  userId       Int
  cep          String
  street       String
  neighborhood String
  city         String
  state        String
  type         AddressType @default(OTHER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  User             User              @relation(fields: [userId], references: [id])
  meetingProposals MeetingProposal[]
}

model petAddress {
  id           Int    @id @default(autoincrement())
  petId        Int    @unique
  cep          String
  street       String
  neighborhood String
  city         String
  state        String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  Pet Pet @relation(fields: [petId], references: [id])
}

model validateView {
  id       Int      @id @default(autoincrement())
  petId    Int
  userId   Int
  viewDate DateTime @db.Date

  Pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([petId, userId, viewDate])
  @@index([petId, userId])
}

model validadeHeart {
  id     Int @id @default(autoincrement())
  petId  Int
  userId Int

  Pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([petId, userId])
  @@index([petId, userId])
}

enum PetStatus {
  AVAILABLE
  PENDING
  ADOPTED
}

model Pet {
  id        Int    @id @default(autoincrement())
  userId    Int
  name      String
  type      String
  breed     String
  gender    String
  wayOfLyfe String
  age       String
  details   String

  publishedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  viewsCount  Int       @default(0)
  heartsCount Int       @default(0)
  petStatus   PetStatus @default(AVAILABLE)

  toy        String
  food       String
  playPlace  String
  sleepPlace String

  imgs    petImg[]
  address petAddress?

  traits PetTrait[]

  views  validateView[]
  hearts validadeHeart[]

  conversations Conversation[]

  User          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adoptedRecord PetsAdopted?
}

model petImg {
  id    Int    @id @default(autoincrement())
  petId Int
  url   String

  Pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)
}

model Trait {
  id        Int    @id @default(autoincrement())
  key       String @unique
  sortOrder Int    @default(0)

  petTraits       PetTrait[]
  userPreferences UserPreference[]
}

model PetTrait {
  id      Int @id @default(autoincrement())
  petId   Int
  traitId Int
  value   Int

  Pet   Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  Trait Trait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([petId, traitId])
}

model UserPreference {
  id      Int @id @default(autoincrement())
  userId  Int
  traitId Int
  weight  Int @default(0)

  User  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Trait Trait @relation(fields: [traitId], references: [id], onDelete: Cascade)

  @@unique([userId, traitId])
}

enum ConversationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Conversation {
  id                 Int                @id @default(autoincrement())
  adopterId          Int
  ownerId            Int
  petId              Int
  conversationStatus ConversationStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  userAdopter User @relation("ConversationAdopter", fields: [adopterId], references: [id], onDelete: Cascade)
  userOwner   User @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  pet         Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)

  adoptionProcess AdoptionProcess?
  messages        Message[]

  @@unique([petId, adopterId])
  @@index([ownerId])
  @@index([adopterId])
  @@index([petId])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("userSentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String // "chat_created", "new_message", "adoption_accepted", etc
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

enum AdoptionStep {
  CONFIRMATION
  MEETING
  MEETING_CONFIRMED
  FINALIZE
  COMPLETED
  DECLINED
}

model AdoptionProcess {
  id             Int @id @default(autoincrement())
  conversationId Int @unique
  petId          Int
  adopterId      Int
  ownerId        Int

  meetingRound Int          @default(1)
  step         AdoptionStep @default(CONFIRMATION)

  adopterConfirmedAt DateTime?
  ownerConfirmedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation        Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  meetingProposals    MeetingProposal[]
  meetingConfirmation MeetingConfirmation?
}

enum MeetingProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MeetingProposalType {
  INITIAL
  RESCHEDULE
}

model MeetingProposal {
  id                Int @id @default(autoincrement())
  adoptionProcessId Int
  createdById       Int

  meetingAt DateTime @db.Timestamptz(0)
  addressId Int?

  round  Int                   @default(1)
  type   MeetingProposalType   @default(INITIAL)
  status MeetingProposalStatus @default(PENDING)

  respondedById Int?
  respondedAt   DateTime?

  createdAt DateTime @default(now())

  address         Address?        @relation(fields: [addressId], references: [id], onDelete: SetNull)
  adoptionProcess AdoptionProcess @relation(fields: [adoptionProcessId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("MeetingProposalCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  respondedBy     User?           @relation("MeetingProposalRespondedBy", fields: [respondedById], references: [id], onDelete: SetNull)

  @@index([adoptionProcessId])
  @@index([createdById])
  @@index([status])
  @@index([addressId])
}

model MeetingConfirmation {
  id                Int @id @default(autoincrement())
  adoptionProcessId Int @unique

  adopterConfirmedAt DateTime?
  ownerConfirmedAt   DateTime?
  finalizedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adoptionProcess AdoptionProcess @relation(fields: [adoptionProcessId], references: [id], onDelete: Cascade)

  @@index([finalizedAt])
}

model PetsAdopted {
  id        Int      @id @default(autoincrement())
  petId     Int
  adopterId Int
  adoptedAt DateTime @default(now())

  Pet  Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  User User @relation(fields: [adopterId], references: [id], onDelete: Cascade)

  @@unique([petId])
  @@index([adopterId])
}

model EmailVerificationCode {
  id Int @id @default(autoincrement())

  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?

  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}
